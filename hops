#!/bin/zsh

function hops() {
  local query="$1"

  local RED=$'\033[0;31m'
  local GREEN=$'\033[1;32m'
  local YELLOW=$'\033[1;33m'
  local BLUE=$'\033[0;34m'
  local CYAN=$'\033[1;36m'
  local NC=$'\033[0m'

  # HELP FLAG
  if [[ "$query" == "-h" ]] || [[ "$query" == "--help" ]]; then
    echo -e "${GREEN}hops${NC} - Homebrew package manager wrapper (like paru for AUR)"
    echo ""
    echo -e "${YELLOW}Usage:${NC}"
    echo "  hops                    Update, upgrade, and cleanup all packages"
    echo "  hops <package>          Search for and install a package interactively"
    echo "  hops -l, --list         List all installed packages (formulae and casks)"
    echo "  hops -r, --remove       Remove installed packages interactively"
    echo "  hops -r <package>       Remove a specific package"
    echo "  hops -h, --help         Show this help message"
    return 0
  fi

  # CHECK DEPENDENCIES
  if ! command -v jq &>/dev/null; then
    echo -e "${YELLOW}jq is required but not installed. Installing...${NC}"
    brew install jq
    echo ""
  fi

  # THROTTLED UPDATE
  _update_homebrew_throttled() {
    local last_update_file="$HOME/.hops_last_update"
    local now=$(date +%s)
    local last_update=$(cat "$last_update_file" 2>/dev/null || echo 0)
    local update_interval=300
    if (( now - last_update > update_interval )); then
      echo -e "${YELLOW}Updating Homebrew...${NC}"
      brew update
      echo "$now" > "$last_update_file"
    else
      local time_remaining=$(( update_interval - (now - last_update) ))
      echo -e "${YELLOW}Homebrew up-to-date (will check again in ${time_remaining}s)${NC}"
    fi
    echo ""
  }

  # ANALYTICS CACHE
  _get_analytics() {
    local cache_dir="$HOME/.hops_cache"
    local formula_cache="$cache_dir/analytics_formula.json"
    local cask_cache="$cache_dir/analytics_cask.json"
    local cache_age_limit=3600
    local now=$(date +%s)
    mkdir -p "$cache_dir"
    if [[ -f "$formula_cache" ]]; then
      local cache_time=$(stat -f%m "$formula_cache" 2>/dev/null || echo 0)
      local cache_age=$(( now - cache_time ))
      if (( cache_age >= cache_age_limit )); then
        rm -f "$formula_cache" "$cask_cache"
        rm -f "$cache_dir/formula_descs.json" "$cache_dir/cask_descs.json" "$cache_dir/formula_counts.json" "$cache_dir/cask_counts.json" "$cache_dir/formula_versions.json" "$cache_dir/cask_versions.json"
      fi
    fi
    if [[ ! -f "$formula_cache" ]]; then
      echo -e "${YELLOW}Fetching analytics (will cache for 1 hour)...${NC}"
      curl -s "https://formulae.brew.sh/api/analytics/install/30d.json" > "$formula_cache"
      curl -s "https://formulae.brew.sh/api/analytics/cask-install/30d.json" > "$cask_cache"
      echo ""
    fi
  }

  # NO ARGUMENTS: full maintenance
  if [[ -z "$query" ]]; then
    echo -e "${YELLOW}Updating Homebrew...${NC}"
    brew update
    echo "$(date +%s)" > "$HOME/.hops_last_update"
    echo ""
    
    # Get list of outdated packages
    local outdated=$(brew outdated)
    if [[ -z "$outdated" ]]; then
      echo -e "${GREEN}All packages are up to date!${NC}"
      return 0
    fi
    
    echo -e "${YELLOW}The following packages will be upgraded:${NC}"
    echo ""
    
    # Parse and display outdated packages with versions
    local -a pkg_array
    while IFS= read -r line; do
      [[ -z "$line" ]] && continue
      pkg_array+=("$line")
    done <<< "$outdated"
    
    local max_name_len=0
    for line in "${pkg_array[@]}"; do
      local pkg_name=$(echo "$line" | awk '{print $1}')
      if (( ${#pkg_name} > max_name_len )); then
        max_name_len=${#pkg_name}
      fi
    done
    
    for line in "${pkg_array[@]}"; do
      local pkg_name=$(echo "$line" | awk '{print $1}')
      local current_ver=$(echo "$line" | awk '{print $2}')
      local latest_ver=$(echo "$line" | awk '{print $4}')
      printf "  ${GREEN}%-${max_name_len}s${NC}  ${CYAN}[%s → %s]${NC}\n" "$pkg_name" "$current_ver" "$latest_ver"
    done
    
    echo ""
    echo -n "${YELLOW}Proceed with upgrade? [y/N]: ${NC}"
    read -r confirm
    
    if [[ "$confirm" != "y" && "$confirm" != "Y" ]]; then
      echo -e "${YELLOW}Cancelled.${NC}"
      return 0
    fi
    
    echo ""
    echo -e "${YELLOW}Upgrading packages...${NC}"
    brew upgrade
    echo ""
    echo -e "${YELLOW}Cleaning up...${NC}"
    brew cleanup
    echo ""
    echo -e "${GREEN}Done!${NC}"
    return 0
  fi

  # LIST FLAG
  if [[ "$query" == "-l" ]] || [[ "$query" == "--list" ]]; then
    echo -e "${YELLOW}Installed packages (formulae):${NC}"
    brew list --formula
    echo ""
    echo -e "${YELLOW}Installed packages (casks):${NC}"
    brew list --cask
    return 0
  fi

  # REMOVE FLAG
  if [[ "$query" == "-r" ]] || [[ "$query" == "--remove" ]]; then
    local search_query="$2"
    if [[ -z "$search_query" ]]; then
      echo -e "${YELLOW}Search for installed package to remove:${NC}"
      read -r search_query
      if [[ -z "$search_query" ]]; then
        echo -e "${RED}No search query provided.${NC}"
        return 1
      fi
    fi

    local -a all_installed
    while IFS= read -r pkg; do
      [[ -z "$pkg" ]] && continue
      all_installed+=("$pkg")
    done < <(brew list --formula && brew list --cask)

    local -a filtered_pkgs
    for pkg in "${all_installed[@]}"; do
      if [[ "$pkg" =~ "$search_query" ]]; then
        filtered_pkgs+=("$pkg")
      fi
    done
    filtered_pkgs=(${(o)filtered_pkgs})

    if [[ ${#filtered_pkgs[@]} -eq 0 ]]; then
      echo -e "${RED}No installed packages matching '$search_query'${NC}"
      return 1
    fi

    local display_i=1
    for pkg in "${filtered_pkgs[@]}"; do
      echo -e "${YELLOW}$((display_i++)). ${GREEN}$pkg${NC}"
    done

    echo ""
    echo -n "${YELLOW}Pick a number to remove (or Ctrl+C to cancel): ${NC}"
    read -r n

    local total_pkgs=${#filtered_pkgs[@]}
    if (( n < 1 || n > total_pkgs )); then
      echo -e "${RED}Invalid selection.${NC}"
      return 1
    fi
    local pkg="${filtered_pkgs[$n]}"
    echo -e "${RED}Removing $pkg...${NC}"
    brew uninstall "$pkg"
    echo ""
    echo -e "${YELLOW}Cleaning up...${NC}"
    brew cleanup
    echo -e "${GREEN}Done!${NC}"
    return 0
  fi

  # SEARCH & INSTALL
  _update_homebrew_throttled
  _get_analytics

  local search_output=$(brew search "$query" 2>/dev/null | grep -v "^=" | grep -v "^$")
  local -a all_search_results
  while IFS= read -r pkg; do
    [[ -z "$pkg" ]] && continue
    all_search_results+=("$pkg")
  done <<< "$search_output"

  if [[ ${#all_search_results[@]} -eq 0 ]]; then
    echo -e "${RED}No packages found for '$query'${NC}"
    return 1
  fi

  echo -e "${YELLOW}Processing ${#all_search_results[@]} packages...${NC}"
  echo ""

  # Build installed versions lookup
  local -A installed_versions
  while IFS= read -r line; do
    [[ -z "$line" ]] && continue
    local pkg=$(echo "$line" | awk '{print $1}')
    local version=$(echo "$line" | awk '{print $2}')
    installed_versions[$pkg]="$version"
  done < <(brew list --versions)

  # Build lookup maps from local cache files (cache processed jq output)
  local cache_dir="$HOME/.hops_cache"
  local formula_descs_cache="$cache_dir/formula_descs.json"
  local cask_descs_cache="$cache_dir/cask_descs.json"
  local formula_counts_cache="$cache_dir/formula_counts.json"
  local cask_counts_cache="$cache_dir/cask_counts.json"
  local formula_versions_cache="$cache_dir/formula_versions.json"
  local cask_versions_cache="$cache_dir/cask_versions.json"

  if [[ ! -f "$formula_descs_cache" ]]; then
    cat "$(brew --cache)/api/formula.jws.json" | jq '.payload | fromjson | map({key: .name, value: .desc}) | from_entries' > "$formula_descs_cache"
  fi
  if [[ ! -f "$cask_descs_cache" ]]; then
    cat "$(brew --cache)/api/cask.jws.json" | jq '.payload | fromjson | map({key: .token, value: .desc}) | from_entries' > "$cask_descs_cache"
  fi
  if [[ ! -f "$formula_counts_cache" ]]; then
    jq '.items | map({key: .formula, value: (.count | gsub(","; "") | tonumber)}) | from_entries' "$cache_dir/analytics_formula.json" > "$formula_counts_cache"
  fi
  if [[ ! -f "$cask_counts_cache" ]]; then
    jq '.items | map({key: .cask, value: (.count | gsub(","; "") | tonumber)}) | from_entries' "$cache_dir/analytics_cask.json" > "$cask_counts_cache"
  fi
  if [[ ! -f "$formula_versions_cache" ]]; then
    cat "$(brew --cache)/api/formula.jws.json" | jq '.payload | fromjson | map({key: .name, value: (.versions.stable // "unknown")}) | from_entries' > "$formula_versions_cache"
  fi
  if [[ ! -f "$cask_versions_cache" ]]; then
    cat "$(brew --cache)/api/cask.jws.json" | jq '.payload | fromjson | map({key: .token, value: (.version // "unknown")}) | from_entries' > "$cask_versions_cache"
  fi

  local formula_descs=$(cat "$formula_descs_cache")
  local cask_descs=$(cat "$cask_descs_cache")
  local formula_counts=$(cat "$formula_counts_cache")
  local cask_counts=$(cat "$cask_counts_cache")
  local formula_versions=$(cat "$formula_versions_cache")
  local cask_versions=$(cat "$cask_versions_cache")

  # Look up count and description for each result
  local tmpfile=$(mktemp)
  local desc count latest_version
  for pkg in "${all_search_results[@]}"; do

    # Try cask first
    desc=$(echo "$cask_descs" | jq -r --arg p "$pkg" '.[$p] // ""' 2>/dev/null)
    count=$(echo "$cask_counts" | jq -r --arg p "$pkg" '.[$p] // 0' 2>/dev/null)
    latest_version=$(echo "$cask_versions" | jq -r --arg p "$pkg" '.[$p] // "unknown"' 2>/dev/null)

    # Fall back to formula
    if [[ -z "$desc" || "$desc" == "null" ]]; then
      desc=$(echo "$formula_descs" | jq -r --arg p "$pkg" '.[$p] // ""' 2>/dev/null)
      count=$(echo "$formula_counts" | jq -r --arg p "$pkg" '.[$p] // 0' 2>/dev/null)
      latest_version=$(echo "$formula_versions" | jq -r --arg p "$pkg" '.[$p] // "unknown"' 2>/dev/null)
    fi

    [[ -z "$desc" || "$desc" == "null" ]] && desc="No description available"
    [[ -z "$count" || "$count" == "null" ]] && count=0
    [[ -z "$latest_version" || "$latest_version" == "null" ]] && latest_version="unknown"

    printf '%s|%s|%s|%s\n' "$count" "$pkg" "$desc" "$latest_version" >> "$tmpfile"
  done

  # Sort descending by install count
  local sorted_file=$(mktemp)
  sort -t'|' -k1 -n -r "$tmpfile" > "$sorted_file"
  rm "$tmpfile"

  local -a sorted_results
  while IFS= read -r line; do
    [[ -z "$line" ]] && continue
    sorted_results+=("$line")
  done < "$sorted_file"
  rm "$sorted_file"

  # PAGINATED DISPLAY
  local page_size=20
  local current_page=0
  local total_pages=$(( (${#sorted_results[@]} + page_size - 1) / page_size ))

  while true; do
    local start_idx=$(( current_page * page_size ))
    local -a page_results=("${sorted_results[@]:$start_idx:$page_size}")

    local page_start_num=$(( start_idx + page_size ))
    [[ $page_start_num -gt ${#sorted_results[@]} ]] && page_start_num=${#sorted_results[@]}

    echo -e "${YELLOW}Page $((current_page + 1))/$total_pages${NC}"
    echo ""

    local display_num=$(( start_idx + 1 ))
    local -a display_lines=()
    for line in "${page_results[@]}"; do
      IFS='|' read -r count pkg desc latest_version <<< "$line"
      
      local version_tag=""
      if [[ -n "${installed_versions[$pkg]}" ]]; then
        local installed_ver="${installed_versions[$pkg]}"
        # Strip revision number (e.g., 2.53.0_1 → 2.53.0)
        installed_ver="${installed_ver%_*}"
        if [[ "$installed_ver" == "$latest_version" ]]; then
          version_tag=" ${CYAN}[$installed_ver ✓]${NC}"
        else
          version_tag=" ${CYAN}[$installed_ver → $latest_version]${NC}"
        fi
      else
        version_tag=" ${CYAN}[$latest_version]${NC}"
      fi
      
      display_lines+=("${YELLOW}$((display_num++)). ${GREEN}$pkg${NC}${version_tag} — ${BLUE}$desc${NC} ${YELLOW}(${count} installs)${NC}")
    done
    for (( i=${#display_lines[@]}-1; i>=0; i-- )); do
      echo -e "${display_lines[$i]}"
    done

    echo ""
    if (( total_pages > 1 )); then
      if (( current_page + 1 < total_pages )) && (( current_page > 0 )); then
        echo -n "${YELLOW}Pick a number, 'n' next page, 'p' previous page, or Ctrl+C to cancel: ${NC}"
      elif (( current_page + 1 < total_pages )); then
        echo -n "${YELLOW}Pick a number, 'n' for next page, or Ctrl+C to cancel: ${NC}"
      else
        echo -n "${YELLOW}Pick a number, 'p' for previous page, or Ctrl+C to cancel: ${NC}"
      fi
    else
      echo -n "${YELLOW}Pick a number or Ctrl+C to cancel: ${NC}"
    fi

    read -r n

    if [[ "$n" == "n" ]] && (( current_page + 1 < total_pages )); then
      ((current_page++))
      echo ""
      continue
    elif [[ "$n" == "p" ]] && (( current_page > 0 )); then
      ((current_page--))
      echo ""
      continue
    elif [[ "$n" =~ ^[0-9]+$ ]]; then
      local total=${#sorted_results[@]}
      if (( n < 1 || n > total )); then
        echo -e "${RED}Invalid selection.${NC}"
        echo ""
      else
        local idx=$(( n ))
        IFS='|' read -r count pkg desc latest_version <<< "${sorted_results[$idx]}"
        echo -e "${GREEN}Installing $pkg...${NC}"
        brew install "$pkg"
        echo ""
        echo -e "${YELLOW}Cleaning up...${NC}"
        brew cleanup
        return 0
      fi
    else
      echo -e "${RED}Invalid input.${NC}"
      return 1
    fi
  done
}

hops "$@"
